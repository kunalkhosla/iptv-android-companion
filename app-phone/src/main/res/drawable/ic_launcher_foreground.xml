<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: the Antenna potato scaled into the 66dp
  safe zone of the 108dp icon canvas. Paths are ported verbatim from
  drawable/brand_mark.xml (32-unit viewport) then placed via a group
  translate(22, 22) + scale 2× — so the drawing occupies units 22..86,
  inside the inner square every launcher mask (circle / square /
  squircle) guarantees to show.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="22"
        android:translateY="22"
        android:scaleX="2"
        android:scaleY="2">

        <!-- Antenna stalks -->
        <path
            android:strokeColor="#D4A544"
            android:strokeWidth="1.4"
            android:strokeLineCap="round"
            android:pathData="M13,12 L9,4" />
        <path
            android:strokeColor="#D4A544"
            android:strokeWidth="1.4"
            android:strokeLineCap="round"
            android:pathData="M19,12 L23,4" />

        <!-- Antenna tips -->
        <path
            android:fillColor="#D4A544"
            android:pathData="M9,2.6 a1.4,1.4 0 1,0 0,2.8 a1.4,1.4 0 1,0 0,-2.8 z" />
        <path
            android:fillColor="#D4A544"
            android:pathData="M23,2.6 a1.4,1.4 0 1,0 0,2.8 a1.4,1.4 0 1,0 0,-2.8 z" />

        <!-- Body -->
        <path
            android:fillColor="#F08245"
            android:pathData="M9,21 Q7,15 11,12 Q15,9 19,11 Q24,12 25,17 Q26,23 22,26 Q17,28 12,26 Q8,25 9,21 Z" />

        <!-- Highlight -->
        <path
            android:fillColor="#FBB27A"
            android:fillAlpha="0.55"
            android:pathData="M10.6,14.5 a2.4,0.9 0 1,0 4.8,0 a2.4,0.9 0 1,0 -4.8,0 z" />

        <!-- Eyes -->
        <path
            android:fillColor="#0D1124"
            android:pathData="M12.3,19 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0 z" />
        <path
            android:fillColor="#0D1124"
            android:pathData="M18.3,19 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0 z" />

        <!-- Smile -->
        <path
            android:strokeColor="#0D1124"
            android:strokeWidth="0.9"
            android:strokeLineCap="round"
            android:pathData="M14,22.5 Q16,24 18,22.5" />
    </group>
</vector>
