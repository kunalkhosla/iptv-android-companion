<?xml version="1.0" encoding="utf-8"?>
<!--
  Antenna potato brand mark — 32-unit viewport, mirrors the inline SVG
  in iptv-webui/public/index.html so the same drawing renders identically
  across both clients. Composition:
    • brass-gold (#D4A544) antenna stalks + tips
    • cyc-light orange (#F08245) body
    • inky navy (#0D1124) eyes + smile (read as negative space)
    • warm peach (#FBB27A) highlight at 55% alpha
  Reused by ic_launcher_foreground.xml (scaled into the adaptive-icon
  safe zone) and banner.xml (scaled up to dominate the TV launcher tile).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="32dp"
    android:height="32dp"
    android:viewportWidth="32"
    android:viewportHeight="32">

    <!-- Antenna stalks -->
    <path
        android:strokeColor="#D4A544"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M13,12 L9,4" />
    <path
        android:strokeColor="#D4A544"
        android:strokeWidth="1.4"
        android:strokeLineCap="round"
        android:pathData="M19,12 L23,4" />

    <!-- Antenna tips (1.4-radius circles drawn as half-arc paths) -->
    <path
        android:fillColor="#D4A544"
        android:pathData="M9,2.6 a1.4,1.4 0 1,0 0,2.8 a1.4,1.4 0 1,0 0,-2.8 z" />
    <path
        android:fillColor="#D4A544"
        android:pathData="M23,2.6 a1.4,1.4 0 1,0 0,2.8 a1.4,1.4 0 1,0 0,-2.8 z" />

    <!-- Body — irregular potato outline -->
    <path
        android:fillColor="#F08245"
        android:pathData="M9,21 Q7,15 11,12 Q15,9 19,11 Q24,12 25,17 Q26,23 22,26 Q17,28 12,26 Q8,25 9,21 Z" />

    <!-- Highlight (warm peach, 55% alpha) — ellipse rx 2.4 ry 0.9 -->
    <path
        android:fillColor="#FBB27A"
        android:fillAlpha="0.55"
        android:pathData="M10.6,14.5 a2.4,0.9 0 1,0 4.8,0 a2.4,0.9 0 1,0 -4.8,0 z" />

    <!-- Eyes -->
    <path
        android:fillColor="#0D1124"
        android:pathData="M12.3,19 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0 z" />
    <path
        android:fillColor="#0D1124"
        android:pathData="M18.3,19 a0.7,0.7 0 1,0 1.4,0 a0.7,0.7 0 1,0 -1.4,0 z" />

    <!-- Smile -->
    <path
        android:strokeColor="#0D1124"
        android:strokeWidth="0.9"
        android:strokeLineCap="round"
        android:pathData="M14,22.5 Q16,24 18,22.5" />
</vector>
